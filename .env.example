# ---- Sui network ----
# Options: devnet | testnet | mainnet | localnet
SUI_NETWORK=mainnet
# Optional explicit RPC (else the SDK uses the public fullnode for SUI_NETWORK)
SUI_FULLNODE_URL=

# ---- Deployed Move package ----
# Fill this AFTER `sui client publish` (see docs/02-deployment-and-github-guide.md)
VEIL_PACKAGE_ID=

# Stable coin type for payouts. Demo default = native SUI so it runs with faucet funds.
# In production this is a (confidential) USDC-style coin type, e.g. 0x...::usdc::USDC
STABLE_COIN_TYPE=0x2::sui::SUI

# ---- Relayer (gas station) ----
# A FUNDED key in `suiprivkey1...` format. NEVER commit a real key.
RELAYER_PRIVATE_KEY=
PORT=8787
WEB_ORIGIN=http://localhost:3000

# ---- Relayer storage ----
# Directory for persistent JSON storage (defaults to ./data)
DATA_DIR=./data

# ---- Relayer authentication ----
# API key for protecting sensitive endpoints (/runs/register-tokens, /audit/*)
# If not set, all endpoints are open (development mode)
# Generate with: openssl rand -hex 32
RELAYER_API_KEY=

# ---- Email notifications ----
# Email service: 'console' (demo) | 'sendgrid' | 'ses' (production)
EMAIL_SERVICE=console
EMAIL_FROM=noreply@veil.payments
# For SendGrid: SENDGRID_API_KEY=SG...
# For AWS SES: AWS_ACCESS_KEY_ID=... AWS_SECRET_ACCESS_KEY=... AWS_REGION=...

# ---- zkLogin (W3) ----
# Google OAuth credentials for zkLogin email-based onboarding
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ZKLOGIN_PROVER_URL=https://prover-dev.mystenlabs.com/v1
SALT_SERVICE_URL=https://salt-api-dev.mystenlabs.com

# ---- DeepBook FX (W4) ----
# DeepBook V3 package ID (mainnet)
DEEPBOOK_PACKAGE_ID=0x337f4f4f6567fcd778d5454f27c16c70e2f274cc6377ea6249ddf491482ef497
# Pool ID for the trading pair you want to support
# SUI/USDC: 0xe05dafb5133bcffb8d59f4e12465dc0e9faeaa05e3e342a08fe135800e3e4407
# DEEP/SUI: 0xb663828d6217467c8a1838a03793da896cbe745b150ebd57d82f814ca579fc22
# DEEP/USDC: 0xf948981b806057580f91622417534f491da5f61aeaf33d0ed8e69fd5691c95ce
# WUSDT/USDC: 0x4e2ca3988246e1d50b9bf209abb9c1cbfec65bd95afdacc620a36c67bdb8452f
DEEPBOOK_POOL_ID=0xe05dafb5133bcffb8d59f4e12465dc0e9faeaa05e3e342a08fe135800e3e4407

# ---- Walrus payslips (W5, optional) ----
WALRUS_PUBLISHER_URL=

# ---- Web (Next.js public env; mirror the values above) ----
NEXT_PUBLIC_SUI_NETWORK=mainnet
NEXT_PUBLIC_VEIL_PACKAGE_ID=
NEXT_PUBLIC_STABLE_COIN_TYPE=0x2::sui::SUI
NEXT_PUBLIC_RELAYER_URL=http://localhost:8787
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
